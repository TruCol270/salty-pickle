# === Required ===
DATABASE_URL=postgresql://user:password@host:5432/salty_pickle
REDIS_URL=redis://host:6379/0
SECRET_KEY=generate-a-strong-random-string-here

# === App ===
DEBUG=false
# Comma-separated and/or JSON array, e.g. https://app.up.railway.app or "https://a.com,https://b.com"
ALLOWED_ORIGINS=https://your-domain.com
FRONTEND_BASE_URL=https://your-domain.com

# === Scheduler (set true ONLY on the worker service) ===
ENABLE_SCHEDULER=false

# === Strava OAuth ===
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=https://your-domain.com/auth/strava/callback

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# === Whoop OAuth ===
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://your-domain.com/auth/whoop/callback

# === OpenAI (for AI plan generation) ===
OPENAI_API_KEY=

# === JWT (optional overrides) ===
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === Dev/Ops (optional) ===
# AUTH_BOOTSTRAP_KEY=
