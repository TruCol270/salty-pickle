# === Required ===
DATABASE_URL=postgresql://user:password@host:5432/salty_pickle
REDIS_URL=redis://host:6379/0
SECRET_KEY=generate-a-strong-random-string-here

# === App ===
DEBUG=false
ENVIRONMENT=production
RELEASE=production
LOG_LEVEL=INFO
SENTRY_DSN=
# Public domains (frontend + API)
APP_PUBLIC_URL=https://app.yourdomain.com
API_PUBLIC_URL=https://api.yourdomain.com
# Comma-separated allowlist for browser origins calling the API (CORS).
# Must include every origin users open in the browser, or OAuth redirect_url validation will reject:
#   - Production custom domain (e.g. https://app.yourdomain.com)
#   - Lovable Cloud publish URL (project subdomain on lovable.app / your chosen publish URL)
#   - Vercel preview deployments if you test against production API (e.g. https://your-app.vercel.app)
#   - Staging host if applicable
# Railway/Heroku-style: you can also set this as a JSON array string, e.g.
#   ["https://app.yourdomain.com","https://preview.vercel.app"]
ALLOWED_ORIGINS=https://app.yourdomain.com,https://staging.yourdomain.com
# Canonical frontend origin used for post-OAuth fallback redirects and /redirect helper page.
# Should match the primary app URL (same host as FRONTEND_BASE_URL in almost all cases).
FRONTEND_BASE_URL=https://app.yourdomain.com
# Railway also supports FRONTEND_URL for CORS. Keep it aligned with your frontend origin(s).
FRONTEND_URL=https://app.yourdomain.com

# === Rate limits ===
RATE_LIMIT_GENERAL=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_FEEDBACK=5/hour

# === Scheduler/runtime service flags ===
# Web service: ENABLE_SCHEDULER=false and WORKER_SERVICE=false.
# Worker service: ENABLE_SCHEDULER=true and WORKER_SERVICE=true.
ENABLE_SCHEDULER=false
WORKER_SERVICE=false
# Days to keep raw provider payloads before cleanup.
RAW_PAYLOAD_RETENTION_DAYS=90

# === Strava OAuth ===
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must be publicly reachable by Strava and exactly match your Strava app callback setting.
STRAVA_REDIRECT_URI=https://api.yourdomain.com/auth/strava/callback

# === Google OAuth ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/auth/google/callback

# === Whoop OAuth ===
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://api.yourdomain.com/auth/whoop/callback

# === OpenAI (for AI plan generation) ===
OPENAI_API_KEY=

# === JWT (optional overrides) ===
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === Dev/Ops (optional) ===
AUTH_BOOTSTRAP_KEY=
GCP_PROJECT_ID=
GCP_REGION=us-central1
