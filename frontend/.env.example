# FastAPI public origin (no trailing slash). Set in Lovable/Vercel to your deployed API host.
VITE_API_BASE_URL=https://api.yourdomain.com
# Optional alias if your template uses this name instead of VITE_API_BASE_URL:
VITE_PUBLIC_API_URL=

# Optional public observability settings. These are embedded in the browser bundle.
VITE_SENTRY_DSN=
VITE_RELEASE=local
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
