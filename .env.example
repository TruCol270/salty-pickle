DATABASE_URL=postgresql://user:password@localhost:5432/salty_pickle
REDIS_URL=redis://localhost:6379/0

STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Must exactly match the callback configured in your Strava app settings.
STRAVA_REDIRECT_URI=http://localhost:8080/auth/strava/callback

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

OPENAI_API_KEY=your_openai_api_key

SECRET_KEY=your-secret-key-for-jwt
DEBUG=true
# Public domains for production hosting (Lovable/Vercel + API host).
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8080
# Include every frontend origin used during local development (scheme + host + port).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Must match the canonical frontend origin you open in the browser.
FRONTEND_BASE_URL=http://localhost:5173

GCP_PROJECT_ID=your-gcp-project
GCP_REGION=us-central1

# Whoop OAuth (get from https://developer.whoop.com)
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REDIRECT_URI=http://localhost:8080/auth/whoop/callback

# Data retention
RAW_PAYLOAD_RETENTION_DAYS=90
